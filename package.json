  "test:sanity": "cucumber-js --config cucumber.js --tags @sanity",

  "test:tag": "cucumber-js --config cucumber.js"
},
  "dependencies": {
    "@cucumber/cucumber": "^9.0.0",
    "playwright": "^1.40.0",
    "winston": "^3.19.0"
  }
}

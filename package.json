{
  "name": "playwright-bdd-js",
  "version": "0.1.0",
  "private": true,
  "scripts": {
  "install:browsers": "npx playwright install",

  "test": "cucumber-js --config cucumber.js",

  "test:smoke": "cucumber-js --config cucumber.js --tags @smoke",

